{
  "manifest_version": 3,
  "name": "Social Post to Obsidian",
  "version": "1.3.0",
  "description": "自動將社群貼文存檔至 Obsidian",
  "permissions": [
    "storage",
    "notifications",
    "alarms"
  ],
  "host_permissions": [
    "http://127.0.0.1:27123/*",
    "https://127.0.0.1:27124/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://twitter.com/*",
        "*://x.com/*",
        "*://threads.com/*",
        "*://www.threads.com/*"
      ],
      "js": ["content/interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "*://twitter.com/*",
        "*://x.com/*"
      ],
      "js": ["content/common.js", "content/twitter.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://threads.com/*",
        "*://www.threads.com/*"
      ],
      "js": ["content/common.js", "content/threads.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
